# gitignore

.DS_Store

# Browsers and web applications
chromium/
brave-flags.conf

# GitHub CLI - contains sensitive authentication data
gh/

# Google Cloud SDK - OAuth tokens, refresh tokens, ADC, service account keys
gcloud/

# Claude Code - conversation history, sessions, transcripts (only settings.json is tracked)
claude/*
!claude/settings.json

# Claude agents - ignore all by default, allowlist what should be tracked
agents/*
!agents/skills/
!agents/.skill-lock.json

# Flutter SDK - machine-specific cache/state
flutter/

# Go configuration and telemetry
go/

# IBus input method - contains runtime state
ibus/

# direnv - contains runtime state
direnv/

# wofi - contains configuration files that may be user-specific
wofi/

# Sensitive files
pulse/cookie
qalculate/qalc.history
fcitx/dbus/
fcitx5/conf/cached_layouts

# Temporary and cache files
*.log
*.cache
*.tmp
*token*
*session*
*history*
*cookie*
*password*

# Auto-generated files that shouldn't be tracked
WARP.md
CLAUDE,nd

# Environment variables - machine specific configuration
environment.d/
shell/env.local.*

# Browser data (VERY SENSITIVE - contains passwords, cookies, history)
chromium/
brave-flags.conf
chromium-flags.conf

# System configuration files (machine-specific)
dconf/user
user-dirs.dirs
user-dirs.locale

# System services with hardcoded paths
systemd/user/timers.target.wants/
systemd/user/tray.target

# Archivos de backup de home-manager
*.backup

# Ignore build outputs from performing a nix-build or `nix build` command
result
result-*

# Ignore automatically generated direnv output
.direnv
configstore/

# TPM plugins (third-party, installed at runtime)
tmux/plugins/
tmux/resurrect/

