{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node", "bun-types"],
    "baseUrl": "."
  },
  "include": ["index.ts", "src/**/*.ts", "test/**/*.ts"]
}
