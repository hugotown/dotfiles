{
  "lastChangelogVersion": "0.80.10",
  "theme": "dark",
  "defaultProvider": "google",
  "defaultModel": "gemini-3.5-flash",
  "defaultThinkingLevel": "high",
  "hideThinkingBlock": false,
  "designDeck": {
    "port": 7777,
    "browser": "/root/.config/pi/agent/design-deck-cloudflared"
  },
  "interview": {
    "port": 32124,
    "timeout": 3600,
    "browser": "/root/.config/pi/agent/interview-cloudflared"
  },
  "npmCommand": [
    "npm"
  ],
  "packages": [
    "npm:pi-boomerang",
    "npm:pi-custom-compaction",
    "npm:pi-design-deck",
    "npm:pi-interactive-shell",
    "npm:pi-intercom",
    "npm:pi-interview",
    "npm:pi-messenger",
    "npm:pi-model-switch",
