# Portable config - works on Nix, NixOS, and Arch Linux

# 1. Environment (loaded via ~/.zshenv -> env.zsh for ALL zsh invocations)

# 2. Tracked integrations
[ -f ~/.config/shell/integrations/zoxide.zsh ] && source ~/.config/shell/integrations/zoxide.zsh
[ -f ~/.config/shell/integrations/atuin.zsh ] && source ~/.config/shell/integrations/atuin.zsh
[ -f ~/.config/shell/integrations/yazi.zsh ] && source ~/.config/shell/integrations/yazi.zsh
command -v mise >/dev/null && eval "$(mise activate zsh)"

# 3. Cached integrations
[ -f ~/.cache/shell/starship.zsh ] && source ~/.cache/shell/starship.zsh


# 4. User customizations
alias cldy="claude --dangerously-skip-permissions"
export PATH="$HOME/.opencode/bin:$PATH"

add-secret() {
    [ "$#" -lt 2 ] && { echo "Usage: add-secret VAR_NAME value" >&2; return 1; }
    ~/.config/shell/scripts/add-secret "$1" "$2" && export "$1=$2"
}

# Antigravity (macOS only)
[ -d "$HOME/.antigravity/antigravity/bin" ] && export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

autoload -Uz compinit && compinit
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# Google Cloud SDK (portable paths)
[ -f "$HOME/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/google-cloud-sdk/path.zsh.inc"
[ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/google-cloud-sdk/completion.zsh.inc"

# Google Vertex AI for OpenCode
export GOOGLE_CLOUD_PROJECT=avantechgeneralservices
export VERTEX_LOCATION=global
